{
  "name": "nodeye-js",
  "version": "0.1.1",
  "description": "Zero-config Node.js performance monitor",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "axios": "^1.13.6",
    "ioredis": "^5.10.0",
    "mongoose": "^9.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {
    "axios": ">=0.27",
    "bullmq": ">=3",
    "ioredis": ">=4",
    "mongoose": ">=6",
    "mysql2": ">=2",
    "pg": ">=8"
  },
  "peerDependenciesMeta": {
    "axios": {
      "optional": true
    },
    "bullmq": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "mongoose": {
      "optional": true
    },
    "mysql2": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  },
  "keywords": [
    "nodejs",
    "performance",
    "monitoring",
    "profiling",
    "apm",
    "slow-query",
    "mongoose",
    "axios",
    "ioredis",
    "redis",
    "mongodb",
    "zero-config",
    "observability",
    "debugger",
    "tracing"
  ]
}
